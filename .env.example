# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Payment Provider Configuration (Paystack - Primary)
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# Payment Provider Configuration (Flutterwave - Alternative)
VITE_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST_your_flutterwave_public_key

# Optional: Feature Flags
VITE_ENABLE_REFERRALS=true
VITE_REFERRAL_BONUS_AMOUNT=700
